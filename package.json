    "test": "node --no-warnings --check bin/iola.js && node --no-warnings --check src/cli.js"
  },
  "files": [
    "bin",
    "src",
    "skills",
    "wiki",
    "docs/assets/readme-header.png",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "yoshkar-ola",
    "open-data",
    "mcp",
    "cli"
  ],
  "engines": {
    "node": ">=22.5.0"
  }
}
